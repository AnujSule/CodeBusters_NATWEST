# ── Application ──────────────────────────────────────────────
APP_NAME=DataDialogue
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=datadialogue
POSTGRES_USER=datadialogue_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://datadialogue_user:change_me_in_production@postgres:5432/datadialogue

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_in_production@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_in_production@redis:6379/0

# ── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=datadialogue_minio
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET_NAME=datadialogue-files
MINIO_USE_SSL=false

# ── AI / LLM ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── pgvector ─────────────────────────────────────────────────
VECTOR_COLLECTION_NAME=document_chunks

# ── File Processing ───────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,pdf
CHUNK_SIZE=512
CHUNK_OVERLAP=64
